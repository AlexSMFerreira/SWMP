\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Pipeline architecture: ROS~2 nodes and the topics connecting them.}}{10}{}\protected@file@percent }
\newlabel{fig:pipeline-architecture}{{3}{10}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Sensor frame tree. Static transforms are wired at startup; the map~$\leftrightarrow $~base\_link transform is published live by the pose-broadcasting node. The \texttt  {rslidar} transform remains an identity placeholder pending resolution of a clock-domain timestamp mismatch in the lidar recording.}}{10}{}\protected@file@percent }
\newlabel{fig:tf-frame-tree}{{4}{10}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Synchronized left and right rectified frames at the same instant. The sea surface is largely textureless, and its specular, non-Lambertian highlights reflect differently in each view, so the same water patch looks different between the two cameras --- an adversarial target for photometric stereo matching.}}{11}{}\protected@file@percent }
\newlabel{fig:raw-camera}{{5}{11}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Sky/horizon masking applied by the shared pre-processing stage. The horizon line detected by the Hough transform (yellow) is nudged down by a 1\% safety margin to the mask boundary (red); every pixel above that boundary is excluded from disparity estimation and point-cloud reconstruction, preventing sky matches from corrupting the sea-surface output.}}{12}{}\protected@file@percent }
\newlabel{fig:horizon-detection}{{6}{12}}
\citation{hirschmuller2008stereo}
\citation{DBLP:journals/corr/abs-2007-12140}
\citation{DBLP:journals/corr/abs-2109-07547}
\citation{wang2026waftstereowarpingalonefieldtransforms}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Disparity-backend comparison on a fixed $\sim $90\,s recorded segment.}}{14}{}\protected@file@percent }
\newlabel{tab:disparity-comparison}{{2}{14}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces StereoBM (tuned). On this frame block matching finds essentially no valid disparity on the textureless surface (disparity map is empty after sky masking), and no usable point cloud is produced. This is a single-frame illustration of the low valid-pixel fraction reported in Table~\ref  {tab:disparity-comparison}; over the full run tuned StereoBM does produce a sparse cloud on its better frames.}}{14}{}\protected@file@percent }
\newlabel{fig:sbm-result}{{7}{14}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces StereoSGBM (tuned). The global smoothness term recovers a connected but oblique and noisy point cloud, with a large elevation spread (no clean wave surface) and frequent failures over the specular patches — far denser than StereoBM, but well short of the learned backends.}}{15}{}\protected@file@percent }
\newlabel{fig:sgbm-result}{{8}{15}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces SGM-CUDA (tuned). GPU semi-global matching yields sparse, salt-and-pepper disparity and a noisy, scattered point cloud (large elevation spread, no coherent surface), consistent with the absence of a left--right consistency check in this binding.}}{16}{}\protected@file@percent }
\newlabel{fig:sgm-cuda-result}{{9}{16}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces HITNet. The learned backbone recovers dense disparity across the textureless surface, yielding a dense point cloud — though noisier than RAFT/WAFT (larger elevation spread), consistent with its higher bad:good ratio in Table~\ref  {tab:disparity-comparison}.}}{17}{}\protected@file@percent }
\newlabel{fig:hitnet-result}{{10}{17}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces RAFT-Stereo. The iterative correlation-volume approach produces dense disparity and a dense, well-structured cloud over the low-texture surface, at the cost of higher latency than HITNet.}}{18}{}\protected@file@percent }
\newlabel{fig:raft-result}{{11}{18}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces WAFT-Stereo. Dense disparity and the cleanest reconstructed surface of the six backends: the bird's-eye elevation view resolves individual wavefronts, and the near-flat residual is consistent with its zero dropped frames and the $H_s$ closest to the altimeter reference in Table~\ref  {tab:disparity-comparison}.}}{19}{}\protected@file@percent }
\newlabel{fig:waft-result}{{12}{19}}
